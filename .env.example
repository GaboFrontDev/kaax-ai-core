# API
SERVER_PORT=8000
LOG_LEVEL=INFO
LOG_COLORIZED=true
API_TOKENS=dev-token

# Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
DEFAULT_TEMPERATURE=0.5

# Agent
DEFAULT_PROMPT_NAME=agent

# Postgres for LangGraph checkpoints
DATABASE_URL=
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=core

# WhatsApp Meta (webhook + outbound)
WHATSAPP_PROVIDER=meta
WHATSAPP_META_VERIFY_TOKEN=
WHATSAPP_META_APP_SECRET=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_API_VERSION=v21.0
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_PROMPT_NAME=agent
WHATSAPP_META_MODEL_NAME=
WHATSAPP_META_TEMPERATURE=

# WhatsApp Calling (Meta Calling API)
# The webhook endpoint is /calls (or /api/channels/whatsapp/meta/calls).
# If not set, VERIFY_TOKEN/APP_SECRET fall back to WHATSAPP_META_* values.
WHATSAPP_CALLS_VERIFY_TOKEN=
WHATSAPP_CALLS_APP_SECRET=
WHATSAPP_CALLS_PROMPT_NAME=voice_agent
WHATSAPP_CALLS_MODEL_NAME=
WHATSAPP_CALLS_TEMPERATURE=
WHATSAPP_CALLS_INCLUDE_TTS_PAYLOAD=false

# Twilio Voice
VOICE_PROVIDER=twilio
TWILIO_VOICE_AUTH_TOKEN=
TWILIO_VOICE_BASE_URL=https://tu-subdominio.ngrok.io
TWILIO_VOICE_PROMPT_NAME=voice_agent
TWILIO_VOICE_MODEL_NAME=
TWILIO_VOICE_TEMPERATURE=
TWILIO_VOICE_HANDOFF_NUMBER=
TWILIO_VOICE_GREETING=Hola, gracias por llamar a Kaax AI. ¿En qué puedo ayudarte hoy?

# Chainlit
CHAINLIT_API_URL=http://127.0.0.1:8000
CHAINLIT_API_TOKEN=dev-token
CHAINLIT_API_TIMEOUT_SECONDS=90
CHAINLIT_PROMPT_NAME=agent
CHAINLIT_SHOW_TOOL_EVENTS=true
