# API
SERVER_PORT=8000
LOG_LEVEL=INFO
LOG_COLORIZED=true
API_TOKENS=dev-token

# Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-5-20250929-v1:0
DEFAULT_TEMPERATURE=0.5

# Agent
DEFAULT_PROMPT_NAME=agent

# Postgres for LangGraph checkpoints
DATABASE_URL=
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=core
